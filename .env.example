# S-GLOBAL DOMINION — Пример конфигурации .env
# Скопируйте этот файл в .env и заполните реальными значениями

# ── БЕЗОПАСНОСТЬ ──────────────────────────────────────────────────────────────
SECRET_KEY=your_secret_key_here_min_32_chars

# ── БАЗА ДАННЫХ ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://dominion_user:password@db:5432/dominion_db

# ── AI BACKEND SWITCH ─────────────────────────────────────────────────────────
# "gemini"  → прямой Gemini API (для сервера s-global.space без GPU)
# "ollama"  → локальный Ollama (для локальной разработки с GPU)
AI_BACKEND=gemini

# ── GEMINI AI API ─────────────────────────────────────────────────────────────
# Получить ключ: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── YANDEX FLEET API (Парк PRO) ───────────────────────────────────────────────
PRO_YANDEX_PARK_ID=
PRO_YANDEX_CLIENT_ID=
PRO_YANDEX_API_KEY=

# ── YANDEX FLEET API (Парк GO) ────────────────────────────────────────────────
GO_YANDEX_PARK_ID=
GO_YANDEX_CLIENT_ID=
GO_YANDEX_API_KEY=

# ── YANDEX FLEET API (Парк PLUS) ──────────────────────────────────────────────
PLUS_YANDEX_PARK_ID=
PLUS_YANDEX_CLIENT_ID=
PLUS_YANDEX_API_KEY=

# ── YANDEX FLEET API (Парк EXPRESS) ───────────────────────────────────────────
EXPRESS_YANDEX_PARK_ID=
EXPRESS_YANDEX_CLIENT_ID=
EXPRESS_YANDEX_API_KEY=

# ── TELEGRAM БОТЫ ─────────────────────────────────────────────────────────────
TCLUB_BOT_TOKEN=
SGLOBAL_BOT_TOKEN=
ADMIN_ID=

# ── ТЕЛЕФОНИЯ 1ATS ────────────────────────────────────────────────────────────
ATS_API_KEY=
ATS_WEBHOOK_SECRET=

# ── MATRIX / MIKS ─────────────────────────────────────────────────────────────
MATRIX_ACCESS_TOKEN=
MATRIX_ADMIN_ACCESS_TOKEN=
MATRIX_MIKS_ROOM_ID=
MATRIX_ADMIN_SHARED_SECRET=

# ── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── OLLAMA ────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434/v1
