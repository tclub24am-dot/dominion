{% extends "base.html" %}

{% block title %}Аналитика | S-GLOBAL DOMINION{% endblock %}

{% block content %}
<div class="page-header">
    <h1>📊 Аналитика</h1>
    <p class="muted-text">Дашборд метрик и KPI</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
    <div class="card text-center">
        <div class="text-3xl gold-text">—</div>
        <div class="muted-text">Выручка</div>
    </div>
    <div class="card text-center">
        <div class="text-3xl text-green-400">—</div>
        <div class="muted-text">Прибыль</div>
    </div>
    <div class="card text-center">
        <div class="text-3xl text-blue-400">—</div>
        <div class="muted-text">Поездки</div>
    </div>
    <div class="card text-center">
        <div class="text-3xl text-yellow-400">—</div>
        <div class="muted-text">Средний чек</div>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="card">
        <h2 class="text-xl gold-text mb-4">Динамика выручки</h2>
        <div class="empty-state py-8">
            <p class="muted-text">График будет доступен после загрузки данных</p>
        </div>
    </div>
    <div class="card">
        <h2 class="text-xl gold-text mb-4">Распределение по паркам</h2>
        <div class="empty-state py-8">
            <p class="muted-text">График будет доступен после загрузки данных</p>
        </div>
    </div>
</div>

<div class="card mt-6">
    <h2 class="text-xl gold-text mb-4">Ключевые показатели</h2>
    <div class="empty-state">
        <h3>Нет данных</h3>
        <p>Данные аналитики появятся после начала работы системы</p>
    </div>
</div>
{% endblock %}
